  "datasets": {
    "reanalysis-era5-pressure-levels": {
      "label": "ERA5 高空（气压层）",
      "level_type": "pressure",
      "description": "ERA5 气压层再分析数据，覆盖 37 个标准气压层（1000 hPa → 1 hPa），提供温压湿风等三维大气变量。",
      "resolution": "0.25°",
      "temporal": "1940 — 至今，逐小时",
      "variables_count": "~16",
      "use_cases": ["天气系统三维结构分析", "大气环流诊断", "垂直剖面图", "探空对比", "客观分析"],
      "notes": "下载时需要指定 pressure_level 列表（hPa）。文件较大（16 个变量 × 37 层 × 全球 0.25°）。"
    },
    "reanalysis-era5-single-levels": {
      "label": "ERA5 地表（单层）",
      "level_type": "surface",
      "description": "ERA5 单层再分析数据，包含地表/近地面大气、陆面、海洋波浪等变量。是 ERA5 最全面的单层数据集。",
      "resolution": "0.25°（大气），0.5°（海浪）",
      "temporal": "1940 — 至今，逐小时",
      "variables_count": "~260",
      "use_cases": ["降水/温度/风场气候统计", "极端天气分析", "能量收支", "海洋波浪", "通用气象分析"],
      "notes": "变量最多最全，分辨率适中（27 km）。是大多数气象分析的首选地表数据集。"
    },
    "reanalysis-era5-land": {
      "label": "ERA5-Land（高分陆面）",
      "level_type": "surface",
      "description": "ERA5-Land 是以 ERA5 大气变量为强迫场、在 0.1° 网格上重跑陆面模型生成的高分辨率陆面数据集。非独立同化，而是 replay 陆面分量。",
      "resolution": "0.1°（约 9 km）",
      "temporal": "1950 — 至今，逐小时",
      "variables_count": "~60",
      "use_cases": ["水文模拟", "农业气象", "局地气候分析", "干旱/洪涝监测", "需要高分辨率的陆面研究"],
      "notes": "仅陆面变量。与 ERA5 single-levels 有重叠变量（如 2 米气温、10 米风），但经 lapse rate 订正后数值不同，尤其在山区。不建议用作通用大气分析。"
    },
    "reanalysis-era5-pressure-levels-monthly-means": {
      "label": "ERA5 高空月均值",
      "level_type": "pressure",
      "description": "ERA5 气压层数据的月平均值。与逐小时数据变量相同，但已按月度平均，文件体积大幅减小。适合气候态分析。",
      "resolution": "0.25°",
      "temporal": "1940 — 至今，逐月",
      "variables_count": "~16",
      "use_cases": ["气候态分析", "年际变率研究", "长期趋势分析", "模式评估"],
      "notes": "月均值数据集，不需要 day 参数。下载时请指定 month 但不要传 day。变量与逐小时版相同。"
    },
    "reanalysis-era5-single-levels-monthly-means": {
      "label": "ERA5 地表月均值",
      "level_type": "surface",
      "description": "ERA5 单层数据的月平均值。变量与逐小时版相同，但已按月平均。适合气候统计。",
      "resolution": "0.25°（大气），0.5°（海浪）",
      "temporal": "1940 — 至今，逐月",
      "variables_count": "~260",
      "use_cases": ["气候态分析", "降水/温度月际变率", "长期趋势", "模式评估"],
      "notes": "月均值数据集，不需要 day 参数。变量与逐小时版相同。"
    },
    "reanalysis-era5-land-monthly-means": {
      "label": "ERA5-Land 月均值",
      "level_type": "surface",
      "description": "ERA5-Land 的月平均值。0.1° 高分辨率陆面变量按月平均，适合局地气候研究。",
      "resolution": "0.1°（约 9 km）",
      "temporal": "1950 — 至今，逐月",
      "variables_count": "~60",
      "use_cases": ["高分陆面气候分析", "水文年际变率", "农业气候区划"],
      "notes": "月均值，不需要 day 参数。仅陆面变量。"
    }
  },
  "dataset_comparisons": {
    "single_levels_vs_land": {
      "title": "ERA5 单层 vs ERA5-Land 如何选择？",
      "summary": "ERA5 single-levels 是完整的再分析（大气+陆面+海浪，0.25°），ERA5-Land 是仅陆面的高分 replay（0.1°）。两者有重叠变量（2米气温、10米风等）但数值不完全相同。",
      "when_single_levels": ["做通用天气/气候分析", "需要海洋或海浪变量", "需要 1940—1950 年数据", "与气压层数据联合分析"],
      "when_land": ["需要 0.1° 高分辨率", "做水文/农业/局地气候", "关注土壤湿度、径流等陆面过程", "在复杂地形区域做精细化分析"],
      "overlap_variables": ["2m_temperature", "2m_dewpoint_temperature", "skin_temperature", "snow_depth", "snow_cover", "snow_albedo", "snow_density", "10m_u_component_of_wind", "10m_v_component_of_wind"],
      "why_different": "ERA5-Land 使用 lapse rate 对气温、湿度、气压进行海拔订正（粗网格→细网格），且仅 run 陆面模型，不包含大气同化。因此同名变量在山区差异明显。"
    },
    "hourly_vs_monthly": {
      "title": "ERA5 逐小时 vs 月均值 如何选择？",
      "summary": "逐小时数据保留完整时间分辨率（~8760 层/年），适合天气过程分析；月均值已经平均为 12 层/年，适合气候态统计。变量集合相同。",
      "when_hourly": ["做天气过程分析", "需要日变化信息", "极端事件研究", "与特定日期关联"],
      "when_monthly": ["做气候平均/年际变率", "长期趋势分析", "需要频繁下载大量数据", "文件体积敏感"],
      "dataset_ids": {
        "hourly_pressure": "reanalysis-era5-pressure-levels",
        "hourly_single": "reanalysis-era5-single-levels",
        "monthly_pressure": "reanalysis-era5-pressure-levels-monthly-means",
        "monthly_single": "reanalysis-era5-single-levels-monthly-means"
      },
      "why_different": "月均值是逐小时数据按月的算数平均。由于非线性过程（如降水日变化、辐射日循环），月均值不等于某一天的小时均值。月均值适合气候统计，不适合天气分析。"
    }
  },
